{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "* --help": "allow",
      "* --version": "allow",
      "ls": "allow",
      "ls *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "cd": "allow",
      "cd *": "allow",
      "pwd": "allow",
      "find": "allow",
      "find *": "allow",
      "grep*": "allow",
      "rg*": "allow",
      "diff": "allow",
      "diff *": "allow",
      "curl*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh repo view*": "allow",
      "gh status*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh search*": "allow",
      "gh browse*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh gist list*": "allow",
      "gh gist view*": "allow",
      "gh variable list*": "allow",
      "gh extension list*": "allow",
      "uv run basedpyright*": "allow",
      "basedpyright*": "allow",
      "echo": "allow",
      "echo *": "allow",
      "date": "allow",
      "tree": "allow",
      "tree *": "allow",
      "tldr": "allow",
      "tldr *": "allow",
      "man": "allow",
      "man *": "allow",
      "which": "allow",
      "which *": "allow",
      "whoami": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "du": "allow",
      "du *": "allow",
      "df": "allow",
      "df *": "allow",
      "ps": "allow",
      "ps *": "allow",
      "uptime": "allow",
      "pytest*": "allow",
      "python -m py_compile*": "allow",
      "python3 -m py_compile*": "allow",
      "npm list*": "allow",
      "npm ls*": "allow",
      "npm view*": "allow",
      "npm info*": "allow",
      "npm outdated*": "allow",
      "npm search*": "allow",
      "npm help*": "allow",
      "npm doctor*": "allow",
      "npm audit*": "allow",
      "npm config list*": "allow",
      "npm config get*": "allow",
    },
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "Qwen3 Coder 30B (local)",
          "limit": { "context": 32768, "output": 32768 },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek R1 14B (local, fast)",
          "limit": { "context": 131072, "output": 32768 },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
      },
    },
  },
}
